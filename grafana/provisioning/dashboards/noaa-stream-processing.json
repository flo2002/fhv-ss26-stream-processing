      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "noaa-postgres"
          },
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT DISTINCT ON (d.station_id)\n  COALESCE(m.station_location, d.station_id) AS city,\n  d.station_id,\n  d.observation_day,\n  d.avg_temperature_celsius,\n  d.sample_count,\n  d.updated_at\nFROM noaa_daily_station_average d\nLEFT JOIN noaa_station_metadata m ON m.station_id = d.station_id\nWHERE d.observation_day BETWEEN DATE '2025-01-01' AND DATE '2025-12-31'\nORDER BY d.station_id, d.observation_day DESC\nLIMIT 100;",
          "refId": "A",
          "sql": {
            "columns": [],
            "groupBy": [],
            "limit": 50
          }
        }
      ],
      "title": "Latest Daily Average Temperature By Station",
      "type": "table"
