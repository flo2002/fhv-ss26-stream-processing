        {
          "datasource": {
            "type": "postgres",
            "uid": "noaa-postgres"
          },
          "editorMode": "code",
          "format": "time_series",
          "rawQuery": true,
          "rawSql": "SELECT\n  d.observation_day::timestamp AS time,\n  COALESCE(m.station_location || ' (' || d.station_id || ')', d.station_id) AS metric,\n  d.avg_temperature_celsius AS value\nFROM noaa_daily_station_average d\nLEFT JOIN noaa_station_metadata m ON m.station_id = d.station_id\nWHERE d.observation_day BETWEEN DATE '2025-01-01' AND DATE '2025-12-31'\nORDER BY d.observation_day, metric;",
          "refId": "A",
          "sql": {
            "columns": [],
            "groupBy": [],
            "limit": 50
          }
        }
      ],
      "title": "Daily Average Temperature Per Station",
      "type": "timeseries"
