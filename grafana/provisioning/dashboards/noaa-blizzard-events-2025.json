          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT\n  COALESCE(m.station_location, e.station_id) AS city,\n  e.station_id,\n  e.window_start,\n  e.window_end,\n  e.min_temperature_celsius,\n  e.max_wind_speed_mps,\n  e.precipitation_observation_count,\n  e.sample_count\nFROM noaa_blizzard_events e\nLEFT JOIN noaa_station_metadata m ON m.station_id = e.station_id\nWHERE e.window_start >= TIMESTAMPTZ '2025-01-01 00:00:00+00'\n  AND e.window_start < TIMESTAMPTZ '2026-01-01 00:00:00+00'\nORDER BY e.window_end DESC, e.max_wind_speed_mps DESC, e.min_temperature_celsius ASC\nLIMIT 20;",
          "refId": "A",
          "sql": {
            "columns": [],
            "groupBy": [],
            "limit": 50
