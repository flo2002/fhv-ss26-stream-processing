          },
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT\n  COALESCE(m.station_location, e.station_id) AS city,\n  e.station_id,\n  count(*) AS detected_windows,\n  max(e.max_wind_speed_mps) AS strongest_blizzard_wind,\n  min(e.min_temperature_celsius) AS coldest_detected_temp\nFROM noaa_blizzard_events e\nLEFT JOIN noaa_station_metadata m ON m.station_id = e.station_id\nWHERE e.window_start >= TIMESTAMPTZ '2025-01-01 00:00:00+00'\n  AND e.window_start < TIMESTAMPTZ '2026-01-01 00:00:00+00'\nGROUP BY COALESCE(m.station_location, e.station_id), e.station_id\nORDER BY detected_windows DESC, strongest_blizzard_wind DESC, coldest_detected_temp ASC\nLIMIT 15;",
          "refId": "A",
          "sql": {
