          "rawSql": "SELECT\n  COALESCE(m.station_location, r.station_id) AS city,\n  r.station_id,\n  r.observation_year,\n  r.avg_duration_hours,\n  r.sample_count,\n  r.updated_at\nFROM noaa_yearly_station_rain_duration r\nLEFT JOIN noaa_station_metadata m ON m.station_id = r.station_id\nWHERE r.observation_year = 2025\nORDER BY r.avg_duration_hours DESC, r.station_id\nLIMIT 100;",
