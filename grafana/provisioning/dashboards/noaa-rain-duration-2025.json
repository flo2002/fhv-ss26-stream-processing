          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT\n  COALESCE(m.station_location || ' (' || r.station_id || ')', r.station_id) AS city,\n  r.sample_count AS rain_observations\nFROM noaa_yearly_station_rain_duration r\nLEFT JOIN noaa_station_metadata m ON m.station_id = r.station_id\nWHERE r.observation_year = 2025\nORDER BY r.sample_count DESC, r.station_id\nLIMIT 20;",
