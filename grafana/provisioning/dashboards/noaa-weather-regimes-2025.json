          "format": "table",
          "rawSql": "SELECT\n  COALESCE(m.station_location, r.station_id) AS station,\n  r.station_id,\n  r.observation_date,\n  r.cluster_label,\n  r.avg_temperature_celsius,\n  CASE WHEN r.cluster_label = 'cold_windy_wet' THEN r.avg_wind_speed_mps END AS cold_windy_wet,\n  CASE WHEN r.cluster_label = 'cold_windy_clear' THEN r.avg_wind_speed_mps END AS cold_windy_clear,\n  CASE WHEN r.cluster_label = 'mild_wet' THEN r.avg_wind_speed_mps END AS mild_wet,\n  CASE WHEN r.cluster_label = 'mild_clear_breezy' THEN r.avg_wind_speed_mps END AS mild_clear_breezy,\n  CASE WHEN r.cluster_label = 'hot_dry_clear' THEN r.avg_wind_speed_mps END AS hot_dry_clear,\n  CASE WHEN r.cluster_label = 'volatile_windy' THEN r.avg_wind_speed_mps END AS volatile_windy\nFROM noaa_weather_regimes r\nLEFT JOIN noaa_station_metadata m ON m.station_id = r.station_id\nWHERE r.observation_date BETWEEN DATE '2025-01-01' AND DATE '2025-12-31'\nORDER BY r.avg_temperature_celsius, r.avg_wind_speed_mps\nLIMIT 5000;",
          "refId": "A"
        }
