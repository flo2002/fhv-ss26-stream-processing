          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT\n  COALESCE(m.station_location, f.station_id) AS city,\n  f.station_id,\n  f.window_start,\n  f.window_end,\n  f.slope_per_second,\n  f.current_average,\n  f.forecast_next_24h,\n  f.observation_count,\n  f.updated_at\nFROM noaa_temperature_forecast f\nLEFT JOIN noaa_station_metadata m ON m.station_id = f.station_id\nWHERE window_end >= '2025-01-01' AND window_end <= '2026-01-01'\nORDER BY window_end DESC\nLIMIT 100;",
          "refId": "A"
        }
      ],
      "title": "Recent Temperature Forecasts",
