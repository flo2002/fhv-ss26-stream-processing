          },
          "editorMode": "code",
          "format": "time_series",
          "rawQuery": true,
          "rawSql": "SELECT\n  window_end AS time,\n  COALESCE(m.station_location || ' (' || f.station_id || ')', f.station_id) AS metric,\n  forecast_next_24h AS value\nFROM noaa_temperature_forecast f\nLEFT JOIN noaa_station_metadata m ON m.station_id = f.station_id\nWHERE window_end >= '2025-01-01' AND window_end <= '2026-01-01'\nORDER BY time, metric;",
          "refId": "A"
        }
      ],
      "title": "Temperature Forecast Trend (Next 24h)",
      "type": "timeseries"
