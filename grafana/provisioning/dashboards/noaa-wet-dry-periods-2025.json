          },
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT\n  COALESCE(m.station_location || ' (' || e.station_id || ')', e.station_id) AS station,\n  e.station_id,\n  e.period_start,\n  e.period_end,\n  e.duration_minutes,\n  e.precipitation_observation_count\nFROM noaa_wet_period_events e\nLEFT JOIN noaa_station_metadata m ON m.station_id = e.station_id\nORDER BY e.period_end DESC\nLIMIT 100;",
          "refId": "A"
        }
      ],
      "title": "Latest Wet Periods",
      "type": "table"
