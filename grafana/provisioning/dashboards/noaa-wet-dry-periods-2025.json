      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "noaa-postgres"
          },
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "WITH bucketed AS (\n  SELECT\n    CASE\n      WHEN duration_minutes <= 30 THEN '0-30 min'\n      WHEN duration_minutes <= 60 THEN '31-60 min'\n      WHEN duration_minutes <= 180 THEN '61-180 min'\n      WHEN duration_minutes <= 360 THEN '181-360 min'\n      WHEN duration_minutes <= 720 THEN '361-720 min'\n      ELSE '>720 min'\n    END AS duration_bucket,\n    CASE\n      WHEN duration_minutes <= 30 THEN 1\n      WHEN duration_minutes <= 60 THEN 2\n      WHEN duration_minutes <= 180 THEN 3\n      WHEN duration_minutes <= 360 THEN 4\n      WHEN duration_minutes <= 720 THEN 5\n      ELSE 6\n    END AS bucket_order\n  FROM noaa_wet_period_events\n)\nSELECT duration_bucket, count(*) AS wet_period_count\nFROM bucketed\nGROUP BY duration_bucket, bucket_order\nORDER BY bucket_order;",
          "refId": "A"
        }
      ],
      "title": "Wet Period Count by Duration",
      "type": "barchart"
    }
