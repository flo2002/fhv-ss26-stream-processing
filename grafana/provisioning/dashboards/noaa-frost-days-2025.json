          "rawSql": "SELECT\n  COALESCE(m.station_location, f.station_id) AS city,\n  f.station_id,\n  f.observation_month,\n  f.frost_day_count,\n  f.updated_at\nFROM noaa_monthly_station_frost_days f\nLEFT JOIN noaa_station_metadata m ON m.station_id = f.station_id\nWHERE f.observation_month BETWEEN DATE '2025-01-01' AND DATE '2025-12-01'\nORDER BY f.frost_day_count DESC, f.station_id, f.observation_month\nLIMIT 100;",
