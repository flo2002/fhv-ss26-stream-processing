          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT\n  COALESCE(m.station_location || ' (' || f.station_id || ')', f.station_id) AS city,\n  sum(f.frost_day_count) AS frost_days\nFROM noaa_monthly_station_frost_days f\nLEFT JOIN noaa_station_metadata m ON m.station_id = f.station_id\nWHERE f.observation_month BETWEEN DATE '2025-01-01' AND DATE '2025-12-01'\nGROUP BY city\nORDER BY frost_days DESC, city\nLIMIT 20;",
