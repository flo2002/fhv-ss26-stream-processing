          "editorMode": "code",
          "format": "time_series",
          "rawQuery": true,
          "rawSql": "SELECT\n  f.observation_month::timestamp AS time,\n  COALESCE(m.station_location || ' (' || f.station_id || ')', f.station_id) AS metric,\n  f.frost_day_count AS value\nFROM noaa_monthly_station_frost_days f\nLEFT JOIN noaa_station_metadata m ON m.station_id = f.station_id\nWHERE f.observation_month BETWEEN DATE '2025-01-01' AND DATE '2025-12-01'\nORDER BY f.observation_month, metric;",
          "refId": "A",
